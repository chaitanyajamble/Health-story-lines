// ==================== ENTITIES ====================

package com.healthstorylines.model;

import jakarta.persistence.*;
import jakarta.validation.constraints.*;
import lombok.*;
import java.time.LocalDate;
import java.time.LocalDateTime;
import java.util.List;

// ---------- User ----------
@Entity
@Table(name = "users")
@Data
@NoArgsConstructor
@AllArgsConstructor
@Builder
public class User {

    @Id
    @GeneratedValue(strategy = GenerationType.IDENTITY)
    private Long id;

    @NotBlank
    private String fullName;

    @Email
    @Column(unique = true, nullable = false)
    private String email;

    @NotBlank
    private String passwordHash;

    private LocalDate dateOfBirth;
    private String condition;          // e.g. "Heart Failure", "ADHD"
    private String timezone;

    @OneToMany(mappedBy = "user", cascade = CascadeType.ALL)
    private List<MedicationEntry> medications;

    @OneToMany(mappedBy = "user", cascade = CascadeType.ALL)
    private List<SymptomEntry> symptoms;

    @OneToMany(mappedBy = "user", cascade = CascadeType.ALL)
    private List<VitalEntry> vitals;

    @OneToMany(mappedBy = "user", cascade = CascadeType.ALL)
    private List<MoodEntry> moods;

    @OneToMany(mappedBy = "user", cascade = CascadeType.ALL)
    private List<JournalEntry> journals;

    private LocalDateTime createdAt;
    private LocalDateTime updatedAt;

    @PrePersist
    protected void onCreate() { createdAt = updatedAt = LocalDateTime.now(); }

    @PreUpdate
    protected void onUpdate() { updatedAt = LocalDateTime.now(); }
}


// ---------- MedicationEntry ----------
@Entity
@Table(name = "medication_entries")
@Data @NoArgsConstructor @AllArgsConstructor @Builder
public class MedicationEntry {

    @Id @GeneratedValue(strategy = GenerationType.IDENTITY)
    private Long id;

    @ManyToOne(fetch = FetchType.LAZY)
    @JoinColumn(name = "user_id", nullable = false)
    private User user;

    @NotBlank
    private String medicationName;

    private String dosage;           // e.g. "10mg"
    private String frequency;        // e.g. "Twice daily"
    private Boolean taken;
    private LocalDateTime takenAt;
    private String notes;
    private LocalDateTime loggedAt;

    @PrePersist
    protected void onCreate() { loggedAt = LocalDateTime.now(); }
}


// ---------- SymptomEntry ----------
@Entity
@Table(name = "symptom_entries")
@Data @NoArgsConstructor @AllArgsConstructor @Builder
public class SymptomEntry {

    @Id @GeneratedValue(strategy = GenerationType.IDENTITY)
    private Long id;

    @ManyToOne(fetch = FetchType.LAZY)
    @JoinColumn(name = "user_id", nullable = false)
    private User user;

    @NotBlank
    private String symptomName;       // e.g. "Fatigue", "Chest pain"

    @Min(1) @Max(10)
    private Integer severity;         // 1 = mild, 10 = severe

    private String notes;
    private LocalDateTime loggedAt;

    @PrePersist
    protected void onCreate() { loggedAt = LocalDateTime.now(); }
}


// ---------- VitalEntry ----------
@Entity
@Table(name = "vital_entries")
@Data @NoArgsConstructor @AllArgsConstructor @Builder
public class VitalEntry {

    @Id @GeneratedValue(strategy = GenerationType.IDENTITY)
    private Long id;

    @ManyToOne(fetch = FetchType.LAZY)
    @JoinColumn(name = "user_id", nullable = false)
    private User user;

    private Double weight;            // kg
    private Integer systolic;         // blood pressure mmHg
    private Integer diastolic;
    private Integer heartRate;        // bpm
    private Double bloodSugar;        // mmol/L
    private Double oxygenSaturation;  // %
    private Double temperature;       // °C
    private Integer sleepHours;
    private Integer stepsCount;

    private String deviceSource;      // e.g. "Fitbit", "iHealth"
    private LocalDateTime measuredAt;

    @PrePersist
    protected void onCreate() { measuredAt = LocalDateTime.now(); }
}


// ---------- MoodEntry ----------
@Entity
@Table(name = "mood_entries")
@Data @NoArgsConstructor @AllArgsConstructor @Builder
public class MoodEntry {

    public enum MoodLevel { VERY_SAD, SAD, NEUTRAL, HAPPY, VERY_HAPPY }

    @Id @GeneratedValue(strategy = GenerationType.IDENTITY)
    private Long id;

    @ManyToOne(fetch = FetchType.LAZY)
    @JoinColumn(name = "user_id", nullable = false)
    private User user;

    @Enumerated(EnumType.STRING)
    private MoodLevel mood;

    private String triggers;          // e.g. "Work stress", "Good sleep"
    private String notes;
    private LocalDateTime loggedAt;

    @PrePersist
    protected void onCreate() { loggedAt = LocalDateTime.now(); }
}


// ---------- JournalEntry ----------
@Entity
@Table(name = "journal_entries")
@Data @NoArgsConstructor @AllArgsConstructor @Builder
public class JournalEntry {

    @Id @GeneratedValue(strategy = GenerationType.IDENTITY)
    private Long id;

    @ManyToOne(fetch = FetchType.LAZY)
    @JoinColumn(name = "user_id", nullable = false)
    private User user;

    @NotBlank
    private String title;

    @Column(columnDefinition = "TEXT")
    private String content;

    private Boolean isSharedWithDoctor;
    private LocalDateTime createdAt;
    private LocalDateTime updatedAt;

    @PrePersist
    protected void onCreate() { createdAt = updatedAt = LocalDateTime.now(); }

    @PreUpdate
    protected void onUpdate() { updatedAt = LocalDateTime.now(); }
}


