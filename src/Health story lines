package com.healthstorylines.repository;

import com.healthstorylines.model.*;
import org.springframework.data.jpa.repository.*;
import org.springframework.stereotype.Repository;
import java.time.LocalDateTime;
import java.util.List;
import java.util.Optional;

@Repository
public interface UserRepository extends JpaRepository<User, Long> {
    Optional<User> findByEmail(String email);
    boolean existsByEmail(String email);
}

@Repository
public interface MedicationRepository extends JpaRepository<MedicationEntry, Long> {
    List<MedicationEntry> findByUserIdOrderByLoggedAtDesc(Long userId);
    List<MedicationEntry> findByUserIdAndLoggedAtBetween(Long userId,
            LocalDateTime start, LocalDateTime end);
}

@Repository
public interface SymptomRepository extends JpaRepository<SymptomEntry, Long> {
    List<SymptomEntry> findByUserIdOrderByLoggedAtDesc(Long userId);
    List<SymptomEntry> findByUserIdAndSymptomNameContainingIgnoreCase(
            Long userId, String keyword);
}

@Repository
public interface VitalRepository extends JpaRepository<VitalEntry, Long> {
    List<VitalEntry> findByUserIdOrderByMeasuredAtDesc(Long userId);

    @Query("SELECT v FROM VitalEntry v WHERE v.user.id = :userId " +
           "AND v.measuredAt >= :since ORDER BY v.measuredAt DESC")
    List<VitalEntry> findRecentVitals(Long userId, LocalDateTime since);
}

@Repository
public interface MoodRepository extends JpaRepository<MoodEntry, Long> {
    List<MoodEntry> findByUserIdOrderByLoggedAtDesc(Long userId);
}

@Repository
public interface JournalRepository extends JpaRepository<JournalEntry, Long> {
    List<JournalEntry> findByUserIdOrderByCreatedAtDesc(Long userId);
    List<JournalEntry> findByUserIdAndIsSharedWithDoctorTrue(Long userId);
}


