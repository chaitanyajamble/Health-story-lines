// ---------- JournalService ----------
@Service
@RequiredArgsConstructor
public class JournalService {

    private final JournalRepository journalRepo;
    private final UserRepository userRepo;

    @Transactional
    public JournalEntry createEntry(Long userId, JournalRequest req) {
        User user = userRepo.findById(userId)
                .orElseThrow(() -> new RuntimeException("User not found."));
        JournalEntry entry = JournalEntry.builder()
                .user(user)
                .title(req.getTitle())
                .content(req.getContent())
                .isSharedWithDoctor(
                        req.getIsSharedWithDoctor() != null
                        ? req.getIsSharedWithDoctor() : false)
                .build();
        return journalRepo.save(entry);
    }

    public List<JournalEntry> getEntries(Long userId) {
        return journalRepo.findByUserIdOrderByCreatedAtDesc(userId);
    }

    public List<JournalEntry> getSharedWithDoctor(Long userId) {
        return journalRepo.findByUserIdAndIsSharedWithDoctorTrue(userId);
    }
}


// ---------- HealthSummaryService ----------
@Service
@RequiredArgsConstructor
public class HealthSummaryService {

    private final UserRepository userRepo;
    private final VitalService vitalService;
    private final SymptomService symptomService;
    private final MedicationService medicationService;
    private final MoodService moodService;

    public HealthSummaryResponse generateSummary(Long userId) {
        User user = userRepo.findById(userId)
                .orElseThrow(() -> new RuntimeException("User not found."));

        return HealthSummaryResponse.builder()
                .patientName(user.getFullName())
                .condition(user.getCondition())
                .recentVitals(vitalService.getRecentVitals(userId, 7))
                .recentSymptoms(symptomService.getSymptoms(userId))
                .recentMedications(medicationService.getMedications(userId))
                .recentMoods(moodService.getMoods(userId))
                .build();
    }
}


