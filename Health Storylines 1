package com.healthstorylines;

import org.springframework.boot.SpringApplication;
import org.springframework.boot.autoconfigure.SpringBootApplication;
import org.springframework.cache.annotation.EnableCaching;
import org.springframework.scheduling.annotation.EnableAsync;
import org.springframework.scheduling.annotation.EnableScheduling;

/**
 * Health Storylines™ — patient-centric self-care platform.
 *
 * Architecture: Spring Boot 3 · Java 21 · Redis · JWT
 * REST API follows FHIR R4 conventions for health data interoperability.
 */
@SpringBootApplication
@EnableCaching
@EnableAsync
@EnableScheduling
public class HealthStorylinesApplication {

    public static void main(String[] args) {
        SpringApplication.run(HealthStorylinesApplication.class, args);
    }
}
package com.healthstorylines.domain.enums;

/**
 * User roles aligned with Health Storylines™ personas.
 */
public enum Role {
    /** Standard app user / patient */
    PATIENT,
    /** Family member or friend invited by patient */
    CAREGIVER,
    /** Physician or nurse with shared-report access */
    CLINICIAN,
    /** Research team member for RWE / DCT */
    RESEARCHER,
    /** Platform administrator */
    ADMIN
}
package com.healthstorylines.domain.enums;

/**
 * Standardised five-point mood scale used across trackers and reports.
 */
public enum MoodLevel {
    VERY_BAD(1, "Very Bad"),
    BAD(2, "Bad"),
    NEUTRAL(3, "Neutral"),
    GOOD(4, "Good"),
    VERY_GOOD(5, "Very Good");

    private final int numericValue;
    private final String label;

    MoodLevel(int numericValue, String label) {
        this.numericValue = numericValue;
        this.label = label;
    }

    public int getNumericValue() { return numericValue; }
    public String getLabel()     { return label; }
}
package com.healthstorylines.domain.enums;

public enum SeverityLevel {
    NONE(0),
    MILD(1),
    MODERATE(2),
    SEVERE(3),
    VERY_SEVERE(4);

    private final int numericValue;

    SeverityLevel(int numericValue) { this.numericValue = numericValue; }

    public int getNumericValue() { return numericValue; }
}
package com.healthstorylines.domain.entity;

import jakarta.persistence.*;
import lombok.Getter;
import lombok.Setter;
import org.springframework.data.annotation.CreatedBy;
import org.springframework.data.annotation.CreatedDate;
import org.springframework.data.annotation.LastModifiedBy;
import org.springframework.data.annotation.LastModifiedDate;
import org.springframework.data.jpa.domain.support.AuditingEntityListener;

import java.time.Instant;
import java.util.UUID;

/**
 * Common audit fields inherited by every persistent entity.
 * Uses Spring Data JPA auditing — requires @EnableJpaAuditing on a config class.
 */
@Getter
@Setter
@MappedSuperclass
@EntityListeners(AuditingEntityListener.class)
public abstract class BaseEntity {

    @Id
    @GeneratedValue(strategy = GenerationType.UUID)
    @Column(updatable = false, nullable = false)
    private UUID id;

    @CreatedDate
    @Column(nullable = false, updatable = false)
    private Instant createdAt;

    @LastModifiedDate
    @Column(nullable = false)
    private Instant updatedAt;

    @CreatedBy
    @Column(updatable = false, length = 100)
    private String createdBy;

    @LastModifiedBy
    @Column(length = 100)
    private String updatedBy;

    @Version
    private Long version;   // Optimistic locking
}
package com.healthstorylines.domain.entity;

import com.healthstorylines.domain.enums.Role;
import jakarta.persistence.*;
import lombok.*;

import java.time.LocalDate;
import java.util.HashSet;
import java.util.Set;

/**
 * Platform user — may be a patient, caregiver, clinician, or researcher.
 */
@Entity
@Table(name = "users",
        uniqueConstraints = @UniqueConstraint(name = "uk_users_email", columnNames = "email"))
@Getter @Setter @NoArgsConstructor @AllArgsConstructor @Builder
public class User extends BaseEntity {

    @Column(nullable = false, length = 100)
    private String firstName;

    @Column(nullable = false, length = 100)
    private String lastName;

    @Column(nullable = false, length = 255)
    private String email;

    @Column(nullable = false)
    private String passwordHash;

    @Enumerated(EnumType.STRING)
    @Column(nullable = false, length = 20)
    @Builder.Default
    private Role role = Role.PATIENT;

    private LocalDate dateOfBirth;

    @Column(length = 10)
    private String gender;

    /** FHIR Patient resource ID for interoperability */
    @Column(length = 100)
    private String fhirPatientId;

    @Column(nullable = false)
    @Builder.Default
    private boolean enabled = true;

    @Column(nullable = false)
    @Builder.Default
    private boolean emailVerified = false;

    /** Caregivers / companions who have been invited */
    @ManyToMany
    @JoinTable(name = "user_caregivers",
            joinColumns = @JoinColumn(name = "patient_id"),
            inverseJoinColumns = @JoinColumn(name = "caregiver_id"))
    @Builder.Default
    private Set<User> caregivers = new HashSet<>();

    // ── Convenience ──────────────────────────────────────────────

    public String getFullName() {
        return firstName + " " + lastName;
    }
}
package com.healthstorylines.domain.entity;

import jakarta.persistence.*;
import lombok.*;

import java.time.LocalDate;
import java.util.ArrayList;
import java.util.List;

/**
 * A medication in the patient's care plan.
 * One patient → many medications; each medication can have many tracker entries.
 */
@Entity
@Table(name = "medications")
@Getter @Setter @NoArgsConstructor @AllArgsConstructor @Builder
public class Medication extends BaseEntity {

    @ManyToOne(fetch = FetchType.LAZY, optional = false)
    @JoinColumn(name = "user_id", nullable = false)
    private User user;

    @Column(nullable = false, length = 200)
    private String name;

    @Column(length = 100)
    private String dosage;              // e.g. "10 mg"

    @Column(length = 100)
    private String frequency;           // e.g. "Twice daily"

    @Column(length = 100)
    private String route;               // e.g. "Oral", "Subcutaneous"

    private LocalDate startDate;
    private LocalDate endDate;

    @Column(columnDefinition = "TEXT")
    private String instructions;

    /** RxNorm concept unique identifier for interoperability */
    @Column(length = 20)
    private String rxNormCode;

    @Column(nullable = false)
    @Builder.Default
    private boolean active = true;

    @OneToMany(mappedBy = "medication", cascade = CascadeType.ALL, orphanRemoval = true)
    @Builder.Default
    private List<MedicationLog> logs = new ArrayList<>();
}
package com.healthstorylines.domain.entity;

import jakarta.persistence.*;
import lombok.*;

import java.time.Instant;

/**
 * Records each time a patient marks a dose as taken, missed, or skipped.
 */
@Entity
@Table(name = "medication_logs")
@Getter @Setter @NoArgsConstructor @AllArgsConstructor @Builder
public class MedicationLog extends BaseEntity {

    @ManyToOne(fetch = FetchType.LAZY, optional = false)
    @JoinColumn(name = "medication_id", nullable = false)
    private Medication medication;

    @Column(nullable = false)
    private Instant scheduledAt;

    private Instant takenAt;

    @Enumerated(EnumType.STRING)
    @Column(nullable = false, length = 20)
    @Builder.Default
    private DoseStatus status = DoseStatus.PENDING;

    @Column(columnDefinition = "TEXT")
    private String notes;

    public enum DoseStatus { PENDING, TAKEN, MISSED, SKIPPED }
}
package com.healthstorylines.domain.entity;

import com.healthstorylines.domain.enums.SeverityLevel;
import jakarta.persistence.*;
import lombok.*;

import java.time.Instant;
import java.util.ArrayList;
import java.util.List;

/**
 * One symptom-tracking event logged by the patient.
 * Supports multiple symptoms per entry (e.g. headache + fatigue at same time).
 */
@Entity
@Table(name = "symptom_entries")
@Getter @Setter @NoArgsConstructor @AllArgsConstructor @Builder
public class SymptomEntry extends BaseEntity {

    @ManyToOne(fetch = FetchType.LAZY, optional = false)
    @JoinColumn(name = "user_id", nullable = false)
    private User user;

    @Column(nullable = false)
    private Instant recordedAt;

    @ElementCollection
    @CollectionTable(name = "symptom_details",
            joinColumns = @JoinColumn(name = "entry_id"))
    @Builder.Default
    private List<SymptomDetail> symptoms = new ArrayList<>();

    @Column(columnDefinition = "TEXT")
    private String notes;

    // ── Embeddable ────────────────────────────────────────────────
    @Embeddable
    @Getter @Setter @NoArgsConstructor @AllArgsConstructor @Builder
    public static class SymptomDetail {
        @Column(nullable = false, length = 200)
        private String name;               // e.g. "Headache", "Fatigue"

        @Enumerated(EnumType.STRING)
        @Column(nullable = false, length = 20)
        private SeverityLevel severity;

        /** SNOMED-CT code for clinical interoperability */
        @Column(length = 20)
        private String snomedCode;
    }
}
