package com.healthstorylines.domain.entity;

import jakarta.persistence.*;
import lombok.*;

import java.time.Instant;
import java.time.LocalDate;
import java.util.HashSet;
import java.util.Set;
import java.util.UUID;

/**
 * A generated health summary sharable with clinicians or caregivers.
 * Covers a date range across all tracked domains.
 */
@Entity
@Table(name = "health_reports")
@Getter @Setter @NoArgsConstructor @AllArgsConstructor @Builder
public class HealthReport extends BaseEntity {

    @ManyToOne(fetch = FetchType.LAZY, optional = false)
    @JoinColumn(name = "user_id", nullable = false)
    private User user;

    @Column(nullable = false)
    private LocalDate fromDate;

    @Column(nullable = false)
    private LocalDate toDate;

    /** Signed URL or storage key for the generated PDF */
    @Column(length = 1000)
    private String reportUrl;

    @Column(nullable = false)
    private Instant generatedAt;

    /** Token used to grant time-limited access to recipients */
    @Column(length = 100, unique = true)
    private String shareToken;

    private Instant shareTokenExpiresAt;

    /** Emails of recipients this report was explicitly shared with */
    @ElementCollection
    @CollectionTable(name = "report_recipients",
            joinColumns = @JoinColumn(name = "report_id"))
    @Column(name = "recipient_email", length = 255)
    @Builder.Default
    private Set<String> sharedWithEmails = new HashSet<>();

    public void generateShareToken() {
        this.shareToken = UUID.randomUUID().toString();
        this.shareTokenExpiresAt = Instant.now().plusSeconds(7 * 24 * 3600); // 7 days
    }
}

